<Window x:Class="ClaudeOrchestrator.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Claude Agent Orchestrator" Width="1400" Height="900"
        Background="#0a0a0a">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="#09090b">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#27272a" BorderThickness="0,0,0,1" Padding="12,10">
                <TextBlock Text="&#x26A1; Claude Orchestrator" Foreground="#60a5fa"
                           FontWeight="Bold" FontSize="13"/>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="AgentsList" Margin="8,8,8,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,6" Padding="10,8" CornerRadius="6"
                                    Cursor="Hand" BorderThickness="1"
                                    BorderBrush="#27272a" Background="#18181b"
                                    MouseDown="AgentCard_MouseDown">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" Foreground="#e4e4e7"
                                               FontSize="12" FontWeight="Medium"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding StatusLabel}" Foreground="#71717a"
                                               FontSize="10" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Margin="8">
                <TextBox x:Name="CwdInput"
                         Background="#18181b" Foreground="#52525b"
                         BorderBrush="#3f3f46" BorderThickness="1"
                         Padding="8,4" FontSize="11" Margin="0,0,0,4"
                         Text="{x:Static sys:Environment.CurrentDirectory}"
                         ToolTip="Working directory"/>
                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="NewAgentInput" Grid.Column="0"
                             Background="#18181b" Foreground="#e4e4e7"
                             BorderBrush="#3f3f46" BorderThickness="1"
                             Padding="8,5" FontSize="12"
                             KeyDown="NewAgentInput_KeyDown"/>
                    <Button Grid.Column="1" Content="+" Margin="4,0,0,0"
                            Padding="10,5" Click="SpawnButton_Click"
                            Background="#2563eb" Foreground="White"
                            BorderThickness="0" FontSize="14" FontWeight="Bold"
                            Cursor="Hand"/>
                </Grid>
                <Button Content="History" HorizontalAlignment="Left"
                        Click="HistoryButton_Click"
                        Background="Transparent" Foreground="#52525b"
                        BorderThickness="0" FontSize="11" Padding="0,4"
                        Cursor="Hand"/>
            </StackPanel>
        </Grid>

        <!-- Terminal area -->
        <Border Grid.Column="1" BorderBrush="#27272a" BorderThickness="1,0,0,0">
            <ContentControl x:Name="TerminalHost"/>
        </Border>
    </Grid>
</Window>
